{
  "name": "nrm-lending",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "turbo run build",
    "db:deploy": "pnpm --filter @repo/db exec prisma migrate deploy",
    "db:generate": "pnpm --filter @repo/db exec prisma generate",
    "db:migrate": "pnpm --filter @repo/db exec prisma migrate dev",
    "db:seed": "pnpm --filter @repo/db exec prisma db seed",
    "db:studio": "pnpm --filter @repo/db exec prisma studio",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "postinstall": "pnpm --filter @repo/db exec prisma generate",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}
